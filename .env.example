# Backend runtime: Azure-first mode. If Azure keys are missing, code falls back
# to local memory/logging so the backend can still start for development.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CASE_STORE_PROVIDER=cosmos
EVENT_PUBLISHER=service_bus
AI_TRIAGE_PROVIDER=azure_openai
VOICE_AI_PROVIDER=openai

# Required: OpenAI GPT Realtime voice bridge
OPENAI_API_KEY=xx-proj-xxx
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
OPENAI_REALTIME_VOICE=alloy

# Required: Twilio voice webhook/phone provider
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=c55xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=xxxx    


# Required for Azure OpenAI triage
AZURE_OPENAI_ENDPOINT=https://xxx.cognitiveservices.azure.com/
AZURE_OPENAI_API_KEY=A2xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# Required for Azure Cosmos DB case/dashboard storage
AZURE_COSMOS_ENDPOINT=https://xxx.documents.azure.com:443/
AZURE_COSMOS_KEY=WGmZ7xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx==
AZURE_COSMOS_DATABASE=crisis_voiceops
AZURE_COSMOS_CASES_CONTAINER=cases
AZURE_COSMOS_RESOURCES_CONTAINER=resources
AZURE_COSMOS_AUDIT_CONTAINER=audit_logs

# Required for Azure Service Bus event publishing
AZURE_SERVICE_BUS_CONNECTION_STRING=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 1.1 Selected Standard
# AZURE_SERVICE_BUS_TOPIC=crisis-events
# AZURE_SERVICE_BUS_QUEUE=

# 1.2 Selected Basic
AZURE_SERVICE_BUS_TOPIC=
AZURE_SERVICE_BUS_QUEUE=crisis-events-queue

# Optional: Azure AI Speech
AZURE_SPEECH_KEY=38xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_SPEECH_REGION=southeastasia
AZURE_SPEECH_RECOGNITION_LANGUAGE=th-TH
AZURE_SPEECH_VOICE=th-TH-PremwadeeNeural

# Optional Azure platform services
AZURE_MAPS_KEY=95xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
APPLICATIONINSIGHTS_CONNECTION_STRING=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KEY_VAULT_URL=https://xxx.vault.azure.net/